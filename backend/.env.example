# ─── Backend environment (set these as Railway variables) ────────────
# Copy to .env for local dev. NEVER commit a real .env.

# CRITICAL for production:
ENVIRONMENT=production
# Generate a strong one:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-a-long-random-string
# Comma/JSON list of allowed browser origins — MUST include the Mini App domain.
CORS_ORIGINS=["https://your-mini-app-domain"]
# Public HTTPS URL of the frontend (the Telegram WebApp). Bot buttons open this.
WEBAPP_URL=https://your-mini-app-domain

# Auth / JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI (optional — keyword fallback used if absent)
ANTHROPIC_API_KEY=
AI_MODEL=claude-haiku-4-5-20251001

# Telegram bot (production bot token from BotFather)
BOT_TOKEN=
DEVELOPER_ID=0

# Database — on Railway use the Postgres plugin's connection string,
# converted to the asyncpg driver: postgresql+asyncpg://USER:PASS@HOST:PORT/DB
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/bfu_db

# Telegram groups every user must join (IDs are negative for supergroups)
TG_GLOBAL_GROUP_ID=0
TG_GLOBAL_GROUP_LINK=
TG_OFFICIAL_CHANNEL_ID=0
TG_OFFICIAL_CHANNEL_LINK=
